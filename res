{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01NgWnQVbnMFJN2HtNiBUHvA","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_013Vqj6i7VEhRi5dS52862Tz","name":"Write","input":{"file_path":"/home/agent/workspace/src/auth/__tests__/oidcClient.spec.ts","content":"/**\n * Unit tests for the oidc-client-ts facade.\n *\n * Mocks the upstream `oidc-client-ts` module so the tests stay hermetic —\n * we only want to assert that the facade constructs the UserManager with\n * the right arguments and that its tiny wrappers forward calls correctly.\n * The real OIDC protocol is covered by the upstream library's own suite.\n */\n\nimport { afterEach, beforeEach, describe, expect, it, vi } from 'vitest'\n\n/* ── Mock oidc-client-ts ────────────────────────────────────────────── */\n\n/**\n * Captured constructor arguments for every `new UserManager(settings)` call.\n * A module-scoped sink keeps the assertions in individual tests concise.\n */\nconst userManagerConstructorCalls: unknown[] = []\n\n/**\n * Captured constructor arguments for every `new WebStorageStateStore(args)`\n * call, one entry per instantiation.\n */\nconst webStorageStateStoreCalls: unknown[] = []\n\nconst mockSigninRedirect = vi.fn().mockResolvedValue(undefined)\nconst mockSigninRedirectCallback = vi.fn().mockResolvedValue({ profile: {} })\nconst mockSignoutRedirect = vi.fn().mockResolvedValue(undefined)\nconst mockGetUser = vi.fn().mockResolvedValue(null)\nconst mockRemoveUser = vi.fn().mockResolvedValue(undefined)\n\nvi.mock('oidc-client-ts', () => {\n  class MockUserManager {\n    public readonly settings: unknown\n    constructor(settings: unknown) {\n      this.settings = settings\n      userManagerConstructorCalls.push(settings)\n    }\n    signinRedirect = mockSigninRedirect\n    signinRedirectCallback = mockSigninRedirectCallback\n    signoutRedirect = mockSignoutRedirect\n    getUser = mockGetUser\n    removeUser = mockRemoveUser\n  }\n\n  class MockWebStorageStateStore {\n    public readonly args: unknown\n    constructor(args: unknown) {\n      this.args = args\n      webStorageStateStoreCalls.push(args)\n    }\n  }\n\n  return {\n    UserManager: MockUserManager,\n    WebStorageStateStore: MockWebStorageStateStore,\n  }\n})\n\n/* ── Imports under test (must come after vi.mock) ───────────────────── */\n\nimport {\n  buildRedirectUri,\n  buildUserManagerSettings,\n  createUserManager,\n  getUser,\n  providerStorageKey,\n  removeUser,\n  signinRedirect,\n  signinRedirectCallback,\n  signoutRedirect,\n} from '@/auth/oidcClient'\nimport {\n  OAUTH_RESPONSE_TYPE_CODE,\n  OIDC_STORAGE_KEY_PREFIX,\n} from '@/auth/constants'\nimport type { OAuthProviderConfig } from '@/auth/types'\n\n/** Minimal, valid provider config used by the majority of tests. */\nconst BASE_PROVIDER: OAuthProviderConfig = Object.freeze({\n  id: 'keycloak',\n  displayName: 'Keycloak',\n  issuer: 'https://id.example.com/realms/main',\n  clientId: 'fdsc-dashboard',\n})\n\n/** A fixed origin to make URL assertions deterministic across environments. */\nconst TEST_ORIGIN = 'https://dashboard.example.com'\n\ndescribe('buildRedirectUri', () => {\n  it('builds an absolute callback URL from the given origin', () => {\n    expect(buildRedirectUri('keycloak', TEST_ORIGIN)).toBe(\n      `${TEST_ORIGIN}/callback/keycloak`,\n    )\n  })\n\n  it('url-encodes the provider id to prevent path injection', () => {\n    expect(buildRedirectUri('a/b', TEST_ORIGIN)).toBe(\n      `${TEST_ORIGIN}/callback/a%2Fb`,\n    )\n  })\n\n  it('falls back to window.location.origin when no origin argument is passed', () => {\n    // jsdom default is http://localhost:3000 or similar; just verify it starts\n    // with the current origin rather than being empty / literal \"undefined\".\n    const uri = buildRedirectUri('keycloak')\n    expect(uri.startsWith(window.location.origin)).toBe(true)\n    expect(uri.endsWith('/callback/keycloak')).toBe(true)\n  })\n})\n\ndescribe('providerStorageKey', () => {\n  it.each([\n    ['keycloak', 'state', `${OIDC_STORAGE_KEY_PREFIX}.keycloak.state`],\n    ['keycloak', 'user', `${OIDC_STORAGE_KEY_PREFIX}.keycloak.user`],\n    ['auth0', 'state', `${OIDC_STORAGE_KEY_PREFIX}.auth0.state`],\n  ])(\n    'builds key for provider=%s slot=%s',\n    (providerId, slot, expected) => {\n      expect(\n        providerStorageKey(providerId, slot as 'state' | 'user'),\n      ).toBe(expected)\n    },\n  )\n})\n\ndescribe('buildUserManagerSettings', () => {\n  it('produces authority, client_id, redirect_uri, response_type, scope', () => {\n    const settings = buildUserManagerSettings(BASE_PROVIDER, TEST_ORIGIN)\n    expect(settings.authority).toBe(BASE_PROVIDER.issuer)\n    expect(settings.client_id).toBe(BASE_PROVIDER.clientId)\n    expect(settings.redirect_uri).toBe(`${TEST_ORIGIN}/callback/keycloak`)\n    expect(settings.response_type).toBe(OAUTH_RESPONSE_TYPE_CODE)\n  })\n\n  it('uses DEFAULT_OAUTH_SCOPES when the provider omits scopes', () => {\n    const settings = buildUserManagerSettings(BASE_PROVIDER, TEST_ORIGIN)\n    expect(settings.scope).toBe('openid profile')\n  })\n\n  it('joins provider-specified scopes with a single space', () => {\n    const settings = buildUserManagerSettings(\n      { ...BASE_PROVIDER, scopes: ['openid', 'profile', 'email'] },\n      TEST_ORIGIN,\n    )\n    expect(settings.scope).toBe('openid profile email')\n  })\n\n  it.each([\n    [true, true],\n    [false, false],\n    [undefined, false],\n  ])(\n    'maps silentRenew=%s to automaticSilentRenew=%s',\n    (silentRenew, expected) => {\n      const settings = buildUserManagerSettings(\n        { ...BASE_PROVIDER, silentRenew },\n        TEST_ORIGIN,\n      )\n      expect(settings.automaticSilentRenew).toBe(expected)\n    },\n  )\n\n  it('installs per-provider WebStorageStateStore prefixes for state and user', () => {\n    webStorageStateStoreCalls.length = 0\n    buildUserManagerSettings(BASE_PROVIDER, TEST_ORIGIN)\n    const prefixes = webStorageStateStoreCalls\n      .map((c) => (c as { prefix?: string }).prefix)\n      .filter((p): p is string => typeof p === 'string')\n    expect(prefixes).toContain(`${OIDC_STORAGE_KEY_PREFIX}.keycloak.state.`)\n    expect(prefixes).toContain(`${OIDC_STORAGE_KEY_PREFIX}.keycloak.user.`)\n  })\n})\n\ndescribe('createUserManager', () => {\n  beforeEach(() => {\n    userManagerConstructorCalls.length = 0\n  })\n\n  it('passes the derived settings to the UserManager constructor', () => {\n    createUserManager(BASE_PROVIDER, TEST_ORIGIN)\n    expect(userManagerConstructorCalls).toHaveLength(1)\n    const settings = userManagerConstructorCalls[0] as Record<string, unknown>\n    expect(settings.authority).toBe(BASE_PROVIDER.issuer)\n    expect(settings.client_id).toBe(BASE_PROVIDER.clientId)\n    expect(settings.redirect_uri).toBe(`${TEST_ORIGIN}/callback/keycloak`)\n    expect(settings.response_type).toBe(OAUTH_RESPONSE_TYPE_CODE)\n  })\n\n  it('isolates two providers with distinct redirect URIs', () => {\n    createUserManager(BASE_PROVIDER, TEST_ORIGIN)\n    createUserManager(\n      { ...BASE_PROVIDER, id: 'auth0', issuer: 'https://example.auth0.com' },\n      TEST_ORIGIN,\n    )\n    const redirects = userManagerConstructorCalls.map(\n      (c) => (c as { redirect_uri: string }).redirect_uri,\n    )\n    expect(redirects).toEqual([\n      `${TEST_ORIGIN}/callback/keycloak`,\n      `${TEST_ORIGIN}/callback/auth0`,\n    ])\n  })\n})\n\ndescribe('facade helpers forward to UserManager methods', () => {\n  beforeEach(() => {\n    mockSigninRedirect.mockClear()\n    mockSigninRedirectCallback.mockClear()\n    mockSignoutRedirect.mockClear()\n    mockGetUser.mockClear()\n    mockRemoveUser.mockClear()\n  })\n\n  afterEach(() => {\n    vi.restoreAllMocks()\n  })\n\n  it('signinRedirect delegates to UserManager#signinRedirect', async () => {\n    const manager = createUserManager(BASE_PROVIDER, TEST_ORIGIN)\n    await signinRedirect(manager)\n    expect(mockSigninRedirect).toHaveBeenCalledTimes(1)\n  })\n\n  it('signinRedirectCallback delegates with the supplied URL', async () => {\n    const manager = createUserManager(BASE_PROVIDER, TEST_ORIGIN)\n    await signinRedirectCallback(manager, 'https://x/callback?code=abc')\n    expect(mockSigninRedirectCallback).toHaveBeenCalledWith(\n      'https://x/callback?code=abc',\n    )\n  })\n\n  it('signoutRedirect delegates to UserManager#signoutRedirect', async () => {\n    const manager = createUserManager(BASE_PROVIDER, TEST_ORIGIN)\n    await signoutRedirect(manager)\n    expect(mockSignoutRedirect).toHaveBeenCalledTimes(1)\n  })\n\n  it('getUser delegates to UserManager#getUser', async () => {\n    const manager = createUserManager(BASE_PROVIDER, TEST_ORIGIN)\n    await getUser(manager)\n    expect(mockGetUser).toHaveBeenCalledTimes(1)\n  })\n\n  it('removeUser delegates to UserManager#removeUser', async () => {\n    const manager = createUserManager(BASE_PROVIDER, TEST_ORIGIN)\n    await removeUser(manager)\n    expect(mockRemoveUser).toHaveBeenCalledTimes(1)\n  })\n})\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":408,"cache_read_input_tokens":68803,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":408},"output_tokens":63,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"08ac2c57-952b-4b40-9997-a87d1906c659","uuid":"4aa5e52a-f415-43d9-9b03-d214d93dcc6a"}
