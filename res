{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01Rs2psFkBUxg4294YKHF1RM","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01N4vawMS3gss5KY5XMh6Wk6","name":"Write","input":{"file_path":"/home/agent/workspace/src/auth/oidcClient.ts","content":"/**\n * Thin per-provider facade over {@link UserManager} from `oidc-client-ts`.\n *\n * The rest of the dashboard (Pinia auth store, router guards, UI) must not\n * depend on `oidc-client-ts` directly — it talks to the helpers exported from\n * this module instead. That keeps the surface area small, makes the store\n * trivial to test with a stub `UserManager`, and isolates the choice of OIDC\n * client library behind a single translation layer.\n *\n * Design notes:\n *\n * - **Flow:** authorisation-code with PKCE. The response type is pinned to\n *   `code` via {@link OAUTH_RESPONSE_TYPE_CODE} — implicit-flow response\n *   types are intentionally not supported.\n * - **Redirect URI:** derived from `window.location.origin` plus the callback\n *   route for the given provider id, so the same build works in Vite dev,\n *   `vite preview`, and production without hard-coded URLs.\n * - **Storage:** per-provider `sessionStorage` stores for both OIDC state\n *   (the short-lived PKCE state / nonce bag) and the `User` object. Using\n *   `sessionStorage` means closing the browser tab logs the user out — a\n *   deliberate security trade-off that avoids a long-lived credential on\n *   shared machines.\n * - **Silent renew:** opt-in per provider via `silentRenew: true`. When\n *   enabled, `oidc-client-ts` renews tokens automatically a minute before\n *   expiry using a hidden iframe.\n */\n\nimport {\n  UserManager,\n  WebStorageStateStore,\n  type User,\n  type UserManagerSettings,\n} from 'oidc-client-ts'\nimport {\n  CALLBACK_ROUTE_TEMPLATE,\n  OAUTH_RESPONSE_TYPE_CODE,\n  OIDC_STORAGE_KEY_PREFIX,\n} from './constants'\nimport { resolveScopes } from './config'\nimport type { OAuthProviderConfig } from './types'\n\n/**\n * Token in {@link CALLBACK_ROUTE_TEMPLATE} that is substituted with the\n * provider id when building the absolute redirect URI.\n */\nconst PROVIDER_ID_PLACEHOLDER = ':providerId' as const\n\n/**\n * Separator used between the scope strings supplied on\n * {@link UserManagerSettings.scope} — OIDC mandates a single space.\n */\nconst SCOPE_SEPARATOR = ' ' as const\n\n/**\n * Build the absolute callback URL that identity providers must be configured\n * to redirect back to after interactive sign-in.\n *\n * Exported so the same value can be used when creating a {@link UserManager}\n * and when wiring the callback route in the router.\n *\n * @param providerId — the id of the configured provider (also used to key\n *   per-provider storage slots).\n * @param origin — the origin to use; defaults to `window.location.origin` so\n *   that the dashboard works in dev, preview, and production without\n *   hard-coded hosts. Tests may pass a deterministic value.\n * @returns an absolute URL ending with the callback path for `providerId`.\n */\nexport function buildRedirectUri(\n  providerId: string,\n  origin: string = typeof window !== 'undefined' ? window.location.origin : '',\n): string {\n  const path = CALLBACK_ROUTE_TEMPLATE.replace(\n    PROVIDER_ID_PLACEHOLDER,\n    encodeURIComponent(providerId),\n  )\n  return `${origin}${path}`\n}\n\n/**\n * Build the `sessionStorage` key suffix used to namespace oidc-client-ts\n * state for a given provider.\n *\n * Two parallel key spaces exist because the upstream library uses two\n * independent stores (`stateStore` for interaction state, `userStore` for\n * the currently-authenticated user). Both are prefixed so operators can\n * clear all dashboard auth state by scanning for the shared prefix.\n *\n * @param providerId — the configured provider id.\n * @param slot — `state` or `user`, matching the two independent stores.\n */\nexport function providerStorageKey(\n  providerId: string,\n  slot: 'state' | 'user',\n): string {\n  return `${OIDC_STORAGE_KEY_PREFIX}.${providerId}.${slot}`\n}\n\n/**\n * Translate a dashboard {@link OAuthProviderConfig} into the settings object\n * consumed by {@link UserManager}.\n *\n * Pulled out of {@link createUserManager} so tests can assert the settings\n * shape without running through the UserManager constructor.\n *\n * @param provider — the dashboard-side provider configuration.\n * @param origin — the origin used to build the redirect URI. Defaults to\n *   `window.location.origin` in the browser.\n */\nexport function buildUserManagerSettings(\n  provider: OAuthProviderConfig,\n  origin?: string,\n): UserManagerSettings {\n  const redirectUri = buildRedirectUri(provider.id, origin)\n  const scopes = resolveScopes(provider).join(SCOPE_SEPARATOR)\n  const stateStorage: Storage | undefined =\n    typeof window !== 'undefined' ? window.sessionStorage : undefined\n\n  const settings: UserManagerSettings = {\n    authority: provider.issuer,\n    client_id: provider.clientId,\n    redirect_uri: redirectUri,\n    post_logout_redirect_uri: origin ?? redirectUri.replace(/\\/callback\\/.*$/, '/'),\n    response_type: OAUTH_RESPONSE_TYPE_CODE,\n    scope: scopes,\n    automaticSilentRenew: provider.silentRenew === true,\n    stateStore: stateStorage\n      ? new WebStorageStateStore({\n          store: stateStorage,\n          prefix: `${providerStorageKey(provider.id, 'state')}.`,\n        })\n      : undefined,\n    userStore: stateStorage\n      ? new WebStorageStateStore({\n          store: stateStorage,\n          prefix: `${providerStorageKey(provider.id, 'user')}.`,\n        })\n      : undefined,\n  }\n\n  return settings\n}\n\n/**\n * Construct a new {@link UserManager} for the given provider configuration.\n *\n * The returned manager is a long-lived object: create it once per provider\n * per session and reuse it. Creating multiple managers for the same provider\n * concurrently is safe but wasteful — they all share the same backing\n * `sessionStorage`.\n *\n * @param provider — the dashboard-side provider configuration.\n * @param origin — optional origin override, useful in tests.\n * @returns a ready-to-use {@link UserManager}.\n */\nexport function createUserManager(\n  provider: OAuthProviderConfig,\n  origin?: string,\n): UserManager {\n  return new UserManager(buildUserManagerSettings(provider, origin))\n}\n\n/**\n * Redirect the browser to the authorisation endpoint to begin interactive\n * sign-in. The promise never resolves in practice because a full-page\n * navigation happens; callers should `await` it only so any configuration\n * errors surface before the redirect.\n *\n * @param manager — a {@link UserManager} from {@link createUserManager}.\n */\nexport async function signinRedirect(manager: UserManager): Promise<void> {\n  await manager.signinRedirect()\n}\n\n/**\n * Complete an interactive sign-in after the identity provider has redirected\n * the browser back to the callback route.\n *\n * @param manager — a {@link UserManager} from {@link createUserManager}.\n * @param url — the full callback URL, including the authorisation-code\n *   query string. Defaults to `window.location.href` when omitted.\n * @returns the freshly authenticated {@link User}.\n */\nexport async function signinRedirectCallback(\n  manager: UserManager,\n  url?: string,\n): Promise<User> {\n  return manager.signinRedirectCallback(url)\n}\n\n/**\n * Redirect the browser to the provider's end-session endpoint (if\n * configured) and clear the locally-stored user.\n *\n * @param manager — a {@link UserManager} from {@link createUserManager}.\n */\nexport async function signoutRedirect(manager: UserManager): Promise<void> {\n  await manager.signoutRedirect()\n}\n\n/**\n * Return the user currently persisted for the manager's provider, or `null`\n * when the session has expired or has been cleared.\n *\n * @param manager — a {@link UserManager} from {@link createUserManager}.\n */\nexport async function getUser(manager: UserManager): Promise<User | null> {\n  return manager.getUser()\n}\n\n/**\n * Remove the persisted user for the manager's provider without contacting\n * the identity provider. Useful for local \"forget me\" flows where a full\n * end-session redirect is undesirable.\n *\n * @param manager — a {@link UserManager} from {@link createUserManager}.\n */\nexport async function removeUser(manager: UserManager): Promise<void> {\n  await manager.removeUser()\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":724,"cache_read_input_tokens":64782,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":724},"output_tokens":9,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"08ac2c57-952b-4b40-9997-a87d1906c659","uuid":"fe06c1c1-918c-42a0-81fe-6382873a660a"}
