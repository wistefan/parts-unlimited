  const uri = buildRedirectUri('keycloak')\n    expect(uri.startsWith(window.location.origin)).toBe(true)\n    expect(uri.endsWith('/callback/keycloak')).toBe(true)\n  })\n})\n\ndescribe('providerStorageKey', () => {\n  it.each([\n    ['keycloak', 'state', `${OIDC_STORAGE_KEY_PREFIX}.keycloak.state`],\n    ['keycloak', 'user', `${OIDC_STORAGE_KEY_PREFIX}.keycloak.user`],\n    ['auth0', 'state', `${OIDC_STORAGE_KEY_PREFIX}.auth0.state`],\n  ])(\n    'builds key for provider=%s slot=%s',\n    (providerId, slot, expected) => {\n      expect(\n        providerStorageKey(providerId, slot as 'state' | 'user'),\n      ).toBe(expected)\n    },\n  )\n})\n\ndescribe('buildUserManagerSettings', () => {\n  it('produces authority, client_id, redirect_uri, response_type, scope', () => {\n    const settings = buildUserManagerSettings(BASE_PROVIDER, TEST_ORIGIN)\n    expect(settings.authority).toBe(BASE_PROVIDER.issuer)\n    expect(settings.client_id).toBe(BASE_PROVIDER.clientId)\n    expect(settings.redirect_uri).toBe(`${TEST_ORIGIN}/callback/keycloak`)\n    expect(settings.response_type).toBe(OAUTH_RESPONSE_TYPE_CODE)\n  })\n\n  it('uses DEFAULT_OAUTH_SCOPES when the provider omits scopes', () => {\n    const settings = buildUserManagerSettings(BASE_PROVIDER, TEST_ORIGIN)\n    expect(settings.scope).toBe('openid profile')\n  })\n\n  it('joins provider-specified scopes with a single space', () => {\n    const settings = buildUserManagerSettings(\n      { ...BASE_PROVIDER, scopes: ['openid', 'profile', 'email'] },\n      TEST_ORIGIN,\n    )\n    expect(settings.scope).toBe('openid profile email')\n  })\n\n  it.each([\n    [true, true],\n    [false, false],\n    [undefined, false],\n  ])(\n    'maps silentRenew=%s to automaticSilentRenew=%s',\n    (silentRenew, expected) => {\n      const settings = buildUserManagerSettings(\n        { ...BASE_PROVIDER, silentRenew },\n        TEST_ORIGIN,\n      )\n      expect(settings.automaticSilentRenew).toBe(expected)\n    },\n  )\n\n  it('installs per-provider WebStorageStateStore prefixes for state and user', () => {\n    webStorageStateStoreCalls.length = 0\n    buildUserManagerSettings(BASE_PROVIDER, TEST_ORIGIN)\n    const prefixes = webStorageStateStoreCalls\n      .map((c) => (c as { prefix?: string }).prefix)\n      .filter((p): p is string => typeof p === 'string')\n    expect(prefixes).toContain(`${OIDC_STORAGE_KEY_PREFIX}.keycloak.state.`)\n    expect(prefixes).toContain(`${OIDC_STORAGE_KEY_PREFIX}.keycloak.user.`)\n  })\n})\n\ndescribe('createUserManager', () => {\n  beforeEach(() => {\n    userManagerConstructorCalls.length = 0\n  })\n\n  it('passes the derived settings to the UserManager constructor', () => {\n    createUserManager(BASE_PROVIDER, TEST_ORIGIN)\n    expect(userManagerConstructorCalls).toHaveLength(1)\n    const settings = userManagerConstructorCalls[0] as Record<string, unknown>\n    expect(settings.authority).toBe(BASE_PROVIDER.issuer)\n    expect(settings.client_id).toBe(BASE_PROVIDER.clientId)\n    expect(settings.redirect_uri).toBe(`${TEST_ORIGIN}/callback/keycloak`)\n    expect(settings.response_type).toBe(OAUTH_RESPONSE_TYPE_CODE)\n  })\n\n  it('isolates two providers with distinct redirect URIs', () => {\n    createUserManager(BASE_PROVIDER, TEST_ORIGIN)\n    createUserManager(\n      { ...BASE_PROVIDER, id: 'auth0', issuer: 'https://example.auth0.com' },\n      TEST_ORIGIN,\n    )\n    const redirects = userManagerConstructorCalls.map(\n      (c) => (c as { redirect_uri: string }).redirect_uri,\n    )\n    expect(redirects).toEqual([\n      `${TEST_ORIGIN}/callback/keycloak`,\n      `${TEST_ORIGIN}/callback/auth0`,\n    ])\n  })\n})\n\ndescribe('facade helpers forward to UserManager methods', () => {\n  beforeEach(() => {\n    mockSigninRedirect.mockClear()\n    mockSigninRedirectCallback.mockClear()\n    mockSignoutRedirect.mockClear()\n    mockGetUser.mockClear()\n    mockRemoveUser.mockClear()\n  })\n\n  afterEach(() => {\n    vi.restoreAllMocks()\n  })\n\n  it('signinRedirect delegates to UserManager#signinRedirect', async () => {\n    const manager = createUserManager(BASE_PROVIDER, TEST_ORIGIN)\n    await signinRedirect(manager)\n    expect(mockSigninRedirect).toHaveBeenCalledTimes(1)\n  })\n\n  it('signinRedirectCallback delegates with the supplied URL', async () => {\n    const manager = createUserManager(BASE_PROVIDER, TEST_ORIGIN)\n    await signinRedirectCallback(manager, 'https://x/callback?code=abc')\n    expect(mockSigninRedirectCallback).toHaveBeenCalledWith(\n      'https://x/callback?code=abc',\n    )\n  })\n\n  it('signoutRedirect delegates to UserManager#signoutRedirect', async () => {\n    const manager = createUserManager(BASE_PROVIDER, TEST_ORIGIN)\n    await signoutRedirect(manager)\n    expect(mockSignoutRedirect).toHaveBeenCalledTimes(1)\n  })\n\n  it('getUser delegates to UserManager#getUser', async () => {\n    const manager = createUserManager(BASE_PROVIDER, TEST_ORIGIN)\n    await getUser(manager)\n    expect(mockGetUser).toHaveBeenCalledTimes(1)\n  })\n\n  it('removeUser delegates to UserManager#removeUser', async () => {\n    const manager = createUserManager(BASE_PROVIDER, TEST_ORIGIN)\n    await removeUser(manager)\n    expect(mockRemoveUser).toHaveBeenCalledTimes(1)\n  })\n})\n","structuredPatch":[],"originalFile":null,"userModified":false}}
